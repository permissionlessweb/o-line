{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "output": {
      "type": "string",
      "description": "Path to write deploy-config.json. Default: ~/.oline/deploy-config.json"
    },
    "profile": {
      "type": "string",
      "description": "Config profile to use (mainnet, testnet, local) [env: OLINE_PROFILE=]",
      "default": "mainnet"
    },
    "list_templates": {
      "type": "boolean",
      "description": "Print available template names and exit"
    }
  },
  "required": []
}
