# ── O-Line Deployer — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in the values.
# Starred (★) fields are required; all others have working defaults.
#
# After filling in secrets, run:
#   oline encrypt          # store mnemonic encrypted on disk
#   oline deploy           # parallel deployment (default)
#   oline deploy --sequential  # sequential deployment (legacy)
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Images ─────────────────────────────────────────────────────────────
OMNIBUS_IMAGE=ghcr.io/permissionlessweb/oline-omnibus:latest
MINIO_IPFS_IMAGE=ghcr.io/permissionlessweb/minio-ipfs:v0.0.9
E2E_OMNIBUS_IMAGE=oline-omnibus:local
E2E_SNAPSHOT_PATH=data/terp-snap-e2e.lz4
RLY_IMAGE=ghcr.io/permissionlessweb/rly-docker:latest
ARGUS_IMAGE=ghcr.io/permissionlessweb/argus:latest

# ── Wallet ★ ──────────────────────────────────────────────────────────────────
# Written by `oline encrypt`. Leave blank until you run that command.
OLINE_ENCRYPTED_MNEMONIC=

# ── Akash Network Endpoints ───────────────────────────────────────────────────
OLINE_RPC_ENDPOINT=https://rpc.akashnet.net:443
OLINE_GRPC_ENDPOINT=https://grpc.akashnet.net:443
# REST (gRPC-Gateway) endpoint — used instead of gRPC for chain queries when set.
# Avoids 503 errors from unreliable gRPC endpoints.
OLINE_REST_ENDPOINT=https://api.akashnet.net:443

# ── Chain Config ──────────────────────────────────────────────────────────────
OLINE_CHAIN_ID=morocco-1
OLINE_BINARY=terpd
OLINE_CHAIN_JSON=https://raw.githubusercontent.com/permissionlessweb/chain-registry/refs/heads/terp%40v5.1.0/terpnetwork/chain.json
OLINE_ADDRBOOK_URL=https://server-4.itrocket.net/mainnet/terp/addrbook.json
OLINE_PERSISTENT_PEERS=5bf887027701d3b8c4d95c0ba898cc8bf6d166ff@188.165.194.110:26676,58e01ab84eb931a82a024324520021d2e075ec67@185.16.39.125:29656,fafb76ea47967a229d092d7ffb0d9957a4254667@94.130.138.48:33656,6f3677c65945ddb6946cbdaa6ec74b4cfec737f8@65.108.232.168:37656,06a68cd28f6b57768c950af7f2ba37b4d8bd7f5e@142.132.248.253:65532,3e04cc80b4647c9ff652d75b0cb12cb6fc36f5d4@46.4.23.120:13656

# ── Private Validator ─────────────────────────────────────────────────────────
# Peer ID of your validator node — kept private from public peers.
OLINE_VALIDATOR_PEER_ID=

# ── SSH ───────────────────────────────────────────────────────────────────────
SSH_PORT=22

# ── Snapshot Export (MinIO S3) ★ ──────────────────────────────────────────────
# Public domain that serves snapshot downloads (used for MinIO HTTP ingress).

OLINE_SNAPSHOT_DOWNLOAD_DOMAIN=snapshots.terp.network
#OLINE_SNAPSHOT_BASE_URL=https://server-4.itrocket.net/mainnet/terp/
#OLINE_SNAPSHOT_STATE_URL=https://server-4.itrocket.net/mainnet/terp/.current_state.json
OLINE_SNAPSHOT_PATH=snapshots/terpnetwork
OLINE_SNAPSHOT_TIME=00:00:00
OLINE_SNAPSHOT_SAVE_FORMAT=tar.gz
OLINE_SNAPSHOT_RETAIN=2 days
OLINE_SNAPSHOT_KEEP_LAST=2
OLINE_AUTOPIN_INTERVAL=300

# ── Cloudflare DNS ────────────────────────────────────────────────────────────
# Required for automatic CNAME + DNSLink management. Leave blank to skip DNS.
OLINE_CF_API_TOKEN=
OLINE_CF_ZONE_ID=

# ── Secrets / Key Storage ─────────────────────────────────────────────────────
SECRETS_PATH=secrets

# ── Phase A: Snapshot Node — domains and ports ★ ─────────────────────────────
RPC_DOMAIN_SNAPSHOT=statesync.terp.network
RPC_PORT_SNAPSHOT=26657
API_DOMAIN_SNAPSHOT=
API_PORT_SNAPSHOT=1317
P2P_DOMAIN_SNAPSHOT=statesync-peer.terp.network
P2P_PORT_SNAPSHOT=26656
GRPC_DOMAIN_SNAPSHOT=
GRPC_PORT_SNAPSHOT=9090

# ── Phase A: Seed Node — domains and ports ★ ─────────────────────────────────
RPC_DOMAIN_SEED=seed-rpc.terp.network
RPC_PORT_SEED=26657
API_DOMAIN_SEED=
API_PORT_SEED=1317
P2P_DOMAIN_SEED=seed.terp.network
P2P_PORT_SEED=26656
GRPC_DOMAIN_SEED=
GRPC_PORT_SEED=9090

# ── Phase B: Left Tackle — domains and ports ─────────────────────────────────
RPC_DOMAIN_TACKLE_L=
RPC_PORT_TACKLE_L=26657
API_DOMAIN_TACKLE_L=
API_PORT_TACKLE_L=1317
P2P_DOMAIN_TACKLE_L=
P2P_PORT_TACKLE_L=26656
GRPC_DOMAIN_TACKLE_L=
GRPC_PORT_TACKLE_L=9090

# ── Phase B: Right Tackle — domains and ports ────────────────────────────────
RPC_DOMAIN_TACKLE_R=
RPC_PORT_TACKLE_R=26657
API_DOMAIN_TACKLE_R=
API_PORT_TACKLE_R=1317
P2P_DOMAIN_TACKLE_R=
P2P_PORT_TACKLE_R=26656
GRPC_DOMAIN_TACKLE_R=
GRPC_PORT_TACKLE_R=9090

# ── Phase C: Left Forward — domains and ports ─────────────────────────────────
RPC_DOMAIN_FORWARD_L=
RPC_PORT_FORWARD_L=26657
API_DOMAIN_FORWARD_L=
API_PORT_FORWARD_L=1317
P2P_DOMAIN_FORWARD_L=
P2P_PORT_FORWARD_L=26656
GRPC_DOMAIN_FORWARD_L=
GRPC_PORT_FORWARD_L=9090

# ── Phase C: Right Forward — domains and ports ────────────────────────────────
RPC_DOMAIN_FORWARD_R=
RPC_PORT_FORWARD_R=26657
API_DOMAIN_FORWARD_R=
API_PORT_FORWARD_R=1317
P2P_DOMAIN_FORWARD_R=
P2P_PORT_FORWARD_R=26656
GRPC_DOMAIN_FORWARD_R=
GRPC_PORT_FORWARD_R=9090

# ── Phase E: IBC Relayer (optional) ──────────────────────────────────────────
RLY_KEY_NAME=relayer_key
RLY_REMOTE_CHAIN_ID=
RLY_API_DOMAIN=
RELAYER_ENTRYPOINT=
# Relayer key mnemonics (secrets — written by `oline encrypt`)
RLY_KEY_TERP=
RLY_KEY_REMOTE=

# ── Phase F: Argus Indexer (optional) ────────────────────────────────────────

ARGUS_ENTRYPOINT_URL=
ARGUS_API_DOMAIN=
ARGUS_NODE_SEEDS=
ARGUS_NODE_PERSISTENT_PEERS=
ARGUS_DB_USER=argus
ARGUS_DB_PASSWORD=
ARGUS_DB_DATA_NAME=argus_data
ARGUS_DB_ACCOUNTS_NAME=argus_accounts

 