#   ${GRPC_DOMAIN}  - domain served for gRPC-Web  (optional, omit block if empty)
#   ${GRPC_PORT}    - internal gRPC-Web port       (default: 9091)
#
# Cosmos SDK exposes two gRPC ports:
#   9090 - native gRPC (HTTP/2 only) — cannot traverse Akash HTTP ingress
#   9091 - gRPC-Web   (HTTP/1.1 compatible) — works through Akash ingress + Cloudflare

upstream grpc_backend {
    server 127.0.0.1:${GRPC_PORT};
}

# ── gRPC-Web — HTTP proxy to cosmos gRPC-Web server ─────────────────────────
# Akash's ingress terminates TLS and forwards HTTP/1.1 to this container.
# Native gRPC (port 9090) requires HTTP/2 end-to-end and cannot traverse
# the Akash ingress. gRPC-Web (port 9091) speaks HTTP/1.1 and works correctly.
server {
    listen 80;
    server_name ${GRPC_DOMAIN};

    location / {
        proxy_pass                      http://grpc_backend;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host             $http_host;
        proxy_set_header X-Forwarded-Proto $scheme;

        add_header Referrer-Policy       'origin';
        add_header Access-Control-Max-Age 3600;
        add_header Access-Control-Expose-Headers Content-Length;
    }
}
