#   ${GRPC_D}  - server_name for TLS gRPC (e.g. grpc.terp.network)
#   ${GRPC_P}    - cosmos native gRPC port   (default: 9090)
#   ${TLS_CERT}     - TLS certificate path      (default: /tmp/tls/cert.pem)
#   ${TLS_KEY}      - TLS private key path      (default: /tmp/tls/privkey.pem)
#
# Nginx terminates TLS on port 9091 (mapped to external 9090 via Akash NodePort).
# This bypasses the Akash HTTP ingress entirely — native gRPC (HTTP/2) works
# because there is no intermediate proxy to downgrade the protocol.
# DNS for ${GRPC_D} must be a grey-cloud (unproxied) A record → provider IP.

server {
    listen      9091 ssl http2;
    server_name ${GRPC_D};

    ssl_certificate     ${TLS_CERT};
    ssl_certificate_key ${TLS_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    location / {
        grpc_pass            grpc://127.0.0.1:${GRPC_P};
        grpc_set_header Host $host;
    }
}
