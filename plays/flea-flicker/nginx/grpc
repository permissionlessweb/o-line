#   ${GRPC_DOMAIN}  - domain served for gRPC  (optional, omit block if empty)
#   ${GRPC_PORT}    - internal gRPC port       (default: 9090)

upstream grpc_backend {
    server 127.0.0.1:${GRPC_PORT};
}

# ── gRPC — HTTP proxy to cosmos gRPC server ─────────────────────────────────
# Akash's ingress terminates TLS and forwards HTTP/1.1 to this container.
# proxy_pass (not grpc_pass) is used because grpc_pass requires HTTP/2 from
# the incoming connection, which Akash ingress does not provide.
server {
    listen 80;
    server_name ${GRPC_DOMAIN};

    location / {
        proxy_pass                      http://grpc_backend;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host             $http_host;
        proxy_set_header X-Forwarded-Proto $scheme;

        add_header Referrer-Policy       'origin';
        add_header Access-Control-Max-Age 3600;
        add_header Access-Control-Expose-Headers Content-Length;
    }
}
