# ── MinIO (Internal S3 Server) ──────────────────────────────────────────────
# Enable internal MinIO server
MINIO_ENABLED=true

# MinIO root credentials (also used as S3 access/secret key)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Auto-pin configuration
AUTOPIN_BUCKETS=snapshots,static,assets,public
AUTOPIN_PATTERNS=*
AUTOPIN_INTERVAL=30



# MinIO S3 API listen port
MINIO_P=9000

# MinIO Console UI port (browse/upload/download files)
MINIO_CONSOLE_P=9001

# ── Service Ports ────────────────────────────────────────────────────────────
# IPFS HTTP gateway port
IPFS_GATEWAY_P=8081

# ── IPFS ─────────────────────────────────────────────────────────────────────
# Kubo init profile (server, lowpower)
IPFS_PROFILE=server

# ── Auto-Pin ─────────────────────────────────────────────────────────────────
# How often to scan MinIO bucket for new snapshots (seconds)
AUTOPIN_INTERVAL=30

# File patterns to auto-pin (comma-separated globs)
AUTOPIN_PATTERNS=*.tar.gz,*.tar.zst,*.tar.lz4,*.tar.xz

# ── User ─────────────────────────────────────────────────────────────────────
# Run services as this UID/GID
PUID=1000
PGID=1000
